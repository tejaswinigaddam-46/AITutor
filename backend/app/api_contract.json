    {
      "name": "AI Tutor (RAG) - answer query",
      "summary": "Answers a question using RAG over stored textbook chunks; optionally links the answer to an existing conversation.",
      "method": "POST",
      "path": "/api/v1/ai/query",
      "headers": {
        "X-API-KEY": "<server-issued-api-key>",
        "Authorization": "Bearer <jwt>"
      },
      "request_schema": {
        "question": "string (required)",
        "book_name": "string (required)",
        "conversation_id": "uuid (optional)"
      },
      "request_example": {
        "question": "Explain Newton's Second Law with an example.",
        "book_name": "GOV_SSC_PHYSICS",
        "conversation_id": "00000000-0000-0000-0000-000000000000"
      },
      "response_schema": {
        "answer": "AITutorResponse | string",
        "sources": "Source[]",
        "summary": "string | null"
      },
      "response_example": {
        "answer": {
          "status": "200",
          "message": "Fetched successfully",
          "topic_breakdown": [
            "Force",
            "Mass",
            "Acceleration"
          ],
          "current_subtopic": "Newton's Second Law",
          "textbook_points": [
            "Force is proportional to acceleration.",
            "F = m * a."
          ],
          "simple_explanation": "The heavier an object is, the more force it needs to speed up by the same amount.",
          "example": "A 2 kg cart needs 6 N to accelerate at 3 m/s^2.",
          "memory_trick": "F = ma: Force makes acceleration.",
          "why_it_works": "It follows from defining net force as the rate of change of momentum.",
          "practice": [
            {
              "question": "If m=5 kg and a=2 m/s^2, what is F?",
              "options": [
                { "id": "A", "text": "10 N" },
                { "id": "B", "text": "7 N" },
                { "id": "C", "text": "2.5 N" },
                { "id": "D", "text": "25 N" }
              ],
              "correct_answer": "A",
              "explanation": "F = m*a = 5*2 = 10 N."
            }
          ],
          "next_step": "Try a problem where two forces act in opposite directions.",
          "summary": "Newton's Second Law relates force, mass and acceleration."
        },
        "sources": [
          {
            "id": 123,
            "curriculum_book_name": "GOV_SSC_PHYSICS",
            "book_name": "Physics",
            "chapter": "Forces",
            "page_number": 42,
            "content": "Newton's Second Law states ...",
            "distance": 0.12,
            "chunk_metadata": {
              "chunk_index": 3
            }
          }
        ],
        "summary": "Newton's Second Law relates force, mass and acceleration."
      }
    },
    {
      "name": "AI Tutor (RAG) - feedback overview",
      "summary": "Generates a teacher-style answer plan/overview for a question assignment (uses question_name as topic) using retrieved textbook context.",
      "method": "POST",
      "path": "/api/v1/ai/feedback-rag",
      "headers": {
        "X-API-KEY": "<server-issued-api-key>",
        "Authorization": "Bearer <jwt>"
      },
      "request_schema": {
        "question_id": "int (required)",
        "no_of_chunks": "int (optional, default 5)",
        "book_name": "string (required)",
        "conversation_id": "uuid | null (optional)"
      },
      "request_example": {
        "question_id": 1,
        "no_of_chunks": 5,
        "book_name": "GOV_SSC_PHYSICS",
        "conversation_id": "00000000-0000-0000-0000-000000000000"
      },
      "response_schema": {
        "answer": "TeacherFeedbackOverviewResponse | string",
        "sources": "Source[]"
      },
      "response_example": {
        "answer": {
          "topic": "Newton's Laws",
          "answer_plan": [
            { "subtopic": "First Law (inertia) - definition and examples" },
            { "subtopic": "Second Law (F = m·a) - explanation and applications" },
            { "subtopic": "Third Law - action and reaction with examples" }
          ]
        },
        "sources": [
          {
            "id": 456,
            "curriculum_book_name": "GOV_SSC_CHEMISTRY",
            "book_name": "Physics",
            "chapter": "Force and Laws of Motion",
            "page_number": 88,
            "content": "Newton's laws of motion describe the relationship between forces and motion ...",
            "distance": 0.19,
            "chunk_metadata": {
              "chunk_index": 1
            }
          }
        ]
      }
    },
    {
      "name": "Documents - upload",
      "summary": "Uploads a textbook chapter (JSON + Markdown) and stores processed chunks in the database/vector store.",
      "method": "POST",
      "path": "/api/v1/documents/upload",
      "headers": {
        "X-API-KEY": "<server-issued-api-key>",
        "Content-Type": "multipart/form-data"
      },
      "request_schema": {
        "curriculum_book_name": "string (required)",
        "document_id": "int (required)",
        "subject": "string (required)",
        "json_file": "file (required)",
        "md_file": "file (required)"
      },
      "request_example": {
        "curriculum_book_name": "GOV_SSC_PHYSICS",
        "document_id": 1,
        "subject": "physics",
        "json_file": "<upload .json file>",
        "md_file": "<upload .md file>"
      },
      "response_example": {
        "filename": "chapter1.md",
        "status": "success"
      }
    },
