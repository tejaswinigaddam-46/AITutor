PROJECT_NAME=AITutor-RAG
API_V1_STR=/api/v1
BACKEND_PORT=8000

# Security
# X-API-KEY header value
API_KEY=your-super-secret-api-key

# CORS Proxy - Allow specific origins (comma separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,https://yourproductiondomain.com

# OpenAI / Groq
EMBEDDING_API_KEY=your_EMBEDDING_API_KEY
GROQ_API_KEY=your_groq_api_key
EMBEDDING_MODEL=your_embedding_model
LLM_MODEL=your_llm_model

# Vector DB (e.g., Chroma, Pinecone, PGVector)
VECTOR_DB_TYPE=postgres
VECTOR_DB_PATH=

# Postgres DB
DB_HOST=localhost
DB_PORT=6432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10

# Other
LOG_LEVEL=INFO
